rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regla simplificada: cualquier usuario autenticado puede leer y escribir.
    // Las restricciones por rol se aplican en la lógica de la app (Flutter + Permisos).
    // Esto evita timeouts causados por get() en las Rules.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
