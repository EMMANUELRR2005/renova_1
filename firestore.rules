rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regla principal: cualquier usuario autenticado puede leer y escribir.
    // NO usar get() ni exists() dentro de las reglas — causan timeouts en escrituras.
    // Las restricciones por rol se aplican en la lógica de la app (Flutter + Permisos).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
